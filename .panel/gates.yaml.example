# Copy to .panel/gates.yaml and customize for your project.
# If gates.yaml is missing, panel uses built-in defaults: compileall + unittest.
gates:
  - name: compileall
    command: python3 -m compileall panel_core tests -q
  - name: unittest
    command: python3 -m unittest discover tests -q
  - name: version-sync
    command: ./scripts/check_version_sync.sh
